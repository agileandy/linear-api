# --- Auth (one of these) ---------------------------------------------------
# Pick the simplest path that fits — see references/auth.md for the full
# decision tree. The skill's CLI reads LINEAR_API_KEY whichever flow filled it.

# Option A — Personal API key. Simplest. Acts as you.
# Get from Linear: Settings -> API -> Personal API keys -> Create.
LINEAR_API_KEY=lin_api_replace_me

# Option B — Bot identity via client_credentials grant (recommended for "my own
# bot in my own workspace"). Register an OAuth app, toggle Client credentials
# ON in its Edit page, copy creds below, then run:
#     uv run python scripts/client_credentials_token.py
# That POSTs grant_type=client_credentials and overwrites LINEAR_API_KEY above
# with a 30-day bot token (lin_oauth_…). Re-run any time to re-mint.
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=

# Option C — Multi-tenant OAuth dance (for distributing the skill to other
# users / workspaces). Run scripts/oauth_dance.py once, then scripts/
# oauth_refresh.py before each 24h expiry. The dance writes LINEAR_API_KEY
# (access token) and LINEAR_OAUTH_REFRESH_TOKEN here.
# LINEAR_OAUTH_REDIRECT_URI=http://localhost:8765/callback
# LINEAR_OAUTH_REFRESH_TOKEN=

# --- Optional --------------------------------------------------------------
# Override the GraphQL endpoint (default: https://api.linear.app/graphql)
# LINEAR_API_URL=https://api.linear.app/graphql
